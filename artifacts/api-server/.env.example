# Copy to Render environment variables (or local .env if you use a loader).
#
# Monorepo note: deploy from the repository root, or ensure workspace deps resolve.
# Suggested Render build (from repo root):
#   pnpm install --frozen-lockfile && pnpm --filter @workspace/api-server run build
# Suggested start:
#   pnpm --filter @workspace/api-server start
#
# If Render "Root Directory" is set to artifacts/api-server, you must still install
# from the monorepo root so workspace packages (@workspace/db, etc.) resolve.

PORT=8080
NODE_ENV=production

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Comma-separated browser origins allowed to call the API (CORS)
CORS_ORIGIN=https://your-frontend.onrender.com,http://localhost:18537

# Optional: absolute base for links in emails / future features
APP_BASE_URL=https://your-frontend.onrender.com

# Logging
LOG_LEVEL=info

# Admin notification email (activation). Email sends only if SMTP is fully configured.
ADMIN_EMAIL=admin@example.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=secret
SMTP_FROM="Topping NFC <noreply@example.com>"

# Twilio SMS verification (required for real SMS membership codes)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+13252254162

# Persistent file storage (required in production)
# Preferred (fastest to configure on Render): Cloudinary
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# Alternative: S3-compatible (AWS S3 / Cloudflare R2 / MinIO)
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional; if empty, server derives a default public URL.
S3_PUBLIC_BASE_URL=
S3_REGION=us-east-1
# Optional; required for non-AWS providers like Cloudflare R2.
S3_ENDPOINT=
